{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Extract": {
    "HeaderFooterMinRepeatCount": 3,
    "HeaderFooterScanLines": 3,
    "HeaderFooterTokenCount": 3
  },
  "Tts": {
    "BaseUrl": "http://localhost:5001"
  },
  "Chunk": {
    "MaxChars": 280
  }
}

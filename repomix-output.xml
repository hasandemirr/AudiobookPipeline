app.MapPut("/api/books/{slug}/sections/{id}",
    async (string slug, string id, HttpRequest request) =>
{
    var manifestPath = Path.Combine(
        repoRoot, "workspace", slug, "manifest.json");

    if (!File.Exists(manifestPath))
        return Results.NotFound(
            new { message = $"{slug} bulunamadı." });

    var body = await new StreamReader(request.Body)
        .ReadToEndAsync();
    var json = System.Text.Json.JsonDocument.Parse(body);

    if (!json.RootElement.TryGetProperty(
        "content", out var contentEl))
        return Results.BadRequest(
            new { message = "content alanı gerekli." });

    var newContent = contentEl.GetString() ?? string.Empty;

    var svc = new ManifestService();
    var manifest = svc.Load(manifestPath);
    var section = manifest.Sections
        .FirstOrDefault(s => s.Id == id);

    if (section is null)
        return Results.NotFound(
            new { message = $"{id} bulunamadı." });

    // reviewed/ klasörüne yaz
    var reviewedDir = Path.Combine(
        repoRoot, "workspace", slug, "reviewed");
    Directory.CreateDirectory(reviewedDir);

    var fileName = Path.GetFileName(section.TxtPath);
    var reviewedPath = Path.Combine(reviewedDir, fileName);

    File.WriteAllText(reviewedPath, newContent,
        System.Text.Encoding.UTF8);

    // Manifest güncelle
    section.ReviewedPath = reviewedPath;
    if (section.Status == "extracted")
        section.Status = "reviewed";

    svc.Save(manifestPath, manifest);

    return Results.Ok(new
    {
        message = "Kaydedildi.",
        id = section.Id,
        status = section.Status,
        reviewedPath
    });
});


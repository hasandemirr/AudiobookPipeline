// GET /api/books/{slug}/export
// Approved section'ları birleştir, txt olarak döndür
app.MapGet("/api/books/{slug}/export", (string slug) =>
{
    var manifestPath = Path.Combine(
        repoRoot, "workspace", slug, "manifest.json");

    if (!File.Exists(manifestPath))
        return Results.NotFound(
            new { message = $"{slug} bulunamadı." });

    var svc = new ManifestService();
    var manifest = svc.Load(manifestPath);

    // Sadece narrate:true ve approved section'lar
    var approvedSections = manifest.Sections
        .Where(s => s.Status == "approved" && s.Narrate)
        .OrderBy(s => s.PageStart)
        .ToList();

    if (!approvedSections.Any())
        return Results.BadRequest(new
        {
            message = "Onaylanmış section bulunamadı.",
            hint = "Önce section'ları onaylayın."
        });

    var parts = new List<string>();

    foreach (var section in approvedSections)
    {
        // Reviewed varsa onu, yoksa extracted'ı al
        var txtPath = !string.IsNullOrEmpty(section.ReviewedPath)
            && File.Exists(section.ReviewedPath)
                ? section.ReviewedPath
                : section.TxtPath;

        if (!File.Exists(txtPath)) continue;

        var content = File.ReadAllText(txtPath,
            System.Text.Encoding.UTF8);
        parts.Add(content.Trim());
    }

    var finalText = string.Join("\n\n", parts);

    // output/ klasörüne de kaydet
    var outputDir = Path.Combine(repoRoot, "output");
    Directory.CreateDirectory(outputDir);
    var outputPath = Path.Combine(outputDir, $"{slug}_export.txt");
    File.WriteAllText(outputPath, finalText,
        System.Text.Encoding.UTF8);

    // HTTP response olarak da döndür
    var bytes = System.Text.Encoding.UTF8.GetBytes(finalText);
    return Results.File(
        bytes,
        contentType: "text/plain; charset=utf-8",
        fileDownloadName: $"{slug}_export.txt");
});


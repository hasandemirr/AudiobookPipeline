using AudiobookPipeline.TextProcessor.Core.Models;
using AudiobookPipeline.TextProcessor.Core.Services;
using AudiobookPipeline.Api.Hubs;
using Microsoft.AspNetCore.SignalR;

var builder = WebApplication.CreateBuilder(args);

// CORS — React UI localhost:5173'ten istek atacak
builder.Services.AddCors(options =>
{
    options.AddDefaultPolicy(policy =>
    {
        policy.WithOrigins(
                "http://localhost:5173",
                "http://localhost:3000")
              .AllowAnyHeader()
              .AllowAnyMethod()
              .AllowCredentials();
    });
});

// SignalR
builder.Services.AddSignalR();

// Servisler
builder.Services.AddSingleton<ManifestService>();

// Repo kökü tespiti
static string FindRepoRoot(string startPath)
{
    var dir = new DirectoryInfo(startPath);
    while (dir != null)
    {
        if (File.Exists(Path.Combine(dir.FullName, ".gitignore")))
            return dir.FullName;
        dir = dir.Parent;
    }
    throw new InvalidOperationException("Repo kökü bulunamadı.");
}

var repoRoot = FindRepoRoot(AppContext.BaseDirectory);

var app = builder.Build();

app.UseCors();

// ─── ENDPOINTS ─────────────────────────────────────

// GET /api/books
// workspace/ altındaki tüm kitapları listele
app.MapGet("/api/books", () =>
{
    var workspaceDir = Path.Combine(repoRoot, "workspace");

    if (!Directory.Exists(workspaceDir))
        return Results.Ok(new List<object>());

    var books = Directory.GetDirectories(workspaceDir)
        .Select(dir =>
        {
            var slug = Path.GetFileName(dir);
            var manifestPath = Path.Combine(dir, "manifest.json");
            var svc = new ManifestService();

            if (!File.Exists(manifestPath))
                return new
                {
                    slug,
                    title = slug,
                    sectionCount = 0,
                    approvedCount = 0,
                    chunkCount = 0,
                    hasManifest = false
                };

            var manifest = svc.Load(manifestPath);
            return new
            {
                slug,
                title = manifest.Book,
                sectionCount = manifest.Sections.Count,
                approvedCount = manifest.Sections
                    .Count(s => s.Status == "approved"),
                chunkCount = manifest.Chunks.Count,
                hasManifest = true
            };
        })
        .ToList();

    return Results.Ok(books);
});

// GET /api/books/{slug}
// Tek kitabın manifest detayı
app.MapGet("/api/books/{slug}", (string slug) =>
{
    var manifestPath = Path.Combine(
        repoRoot, "workspace", slug, "manifest.json");

    if (!File.Exists(manifestPath))
        return Results.NotFound(new { message = $"{slug} bulunamadı." });

    var svc = new ManifestService();
    var manifest = svc.Load(manifestPath);
    return Results.Ok(manifest);
});

// POST /api/books/extract
// PDF extract başlat
app.MapPost("/api/books/extract", async (
    HttpRequest request,
    IHubContext<ProgressHub> hubContext) =>
{
    // Form verisi oku
    if (!request.HasFormContentType)
        return Results.BadRequest(
            new { message = "Form verisi gerekli." });

    var form = await request.ReadFormAsync();
    var slug = form["slug"].ToString();
    var file = form.Files.GetFile("pdf");

    if (string.IsNullOrWhiteSpace(slug))
        return Results.BadRequest(
            new { message = "slug gerekli." });

    if (file is null || file.Length == 0)
        return Results.BadRequest(
            new { message = "PDF dosyası gerekli." });

    // PDF'i assets/raw_pdfs/ altına kaydet
    var pdfDir = Path.Combine(repoRoot, "assets", "raw_pdfs");
    Directory.CreateDirectory(pdfDir);
    var pdfPath = Path.Combine(pdfDir, file.FileName);

    using (var stream = File.Create(pdfPath))
        await file.CopyToAsync(stream);

    var manifestPath = Path.Combine(
        repoRoot, "workspace", slug, "manifest.json");

    // Kitap zaten var mı kontrol et
    var manifestSvcCheck = new ManifestService();
    if (File.Exists(manifestPath))
    {
        // Kilitli mi?
        if (manifestSvcCheck.IsLocked(manifestPath))
            return Results.Conflict(new
            {
                message = $"{slug} şu an işleniyor. Lütfen bekleyin.",
                isLocked = true
            });

        // Kilitli değil ama var — force parametresi gerekir
        var force = form["force"].ToString();
        if (force != "true")
            return Results.Conflict(new
            {
                message = $"{slug} zaten mevcut. Üzerine yazmak için force=true gönderin.",
                isLocked = false,
                exists = true
            });
    }

    // Extract işlemini arka planda başlat
    _ = Task.Run(async () =>
    {
        var manifestSvc = new ManifestService();
        try
        {
            manifestSvc.Lock(manifestPath, "extract");

            await hubContext.Clients.All.SendAsync(
                "ExtractProgress",
                new { slug, message = "Extract başladı...", percent = 0 });

            var workspaceRoot = Path.Combine(
                repoRoot, "workspace", slug);
            var sectionsDir = Path.Combine(workspaceRoot, "sections");
            var rulesPath = Path.Combine(repoRoot, "src",
                "TextProcessor",
                "AudiobookPipeline.TextProcessor",
                "Core", "Rules", "ocr_rules.json");

            Directory.CreateDirectory(sectionsDir);

            var tocParser   = new TocParserService();
            var extractor   = new PdfExtractService();
            var detector    = new HeaderFooterDetector(
                minRepeatCount: 3);
            var ocrFix      = new OcrFixService(rulesPath);

            await hubContext.Clients.All.SendAsync(
                "ExtractProgress",
                new { slug, message = "TOC okunuyor...", percent = 5 });

            var toc = tocParser.HasToc(pdfPath)
                ? tocParser.Parse(pdfPath)
                : new List<TocEntry>
                  {
                      new TocEntry
                      {
                          Level = 1,
                          Title = "Tam Metin",
                          PageStart = 1,
                          PageEnd = int.MaxValue,
                          Narrate = true
                      }
                  };

            await hubContext.Clients.All.SendAsync(
                "ExtractProgress",
                new { slug, 
                      message = $"Sayfalar okunuyor...", 
                      percent = 10 });

            var allPages = extractor.ExtractPages(pdfPath);
            var allTexts = allPages.Select(p => p.Text).ToList();
            var repeatedLines = detector.DetectRepeatedLines(allTexts);

            var manifest = manifestSvc.Load(manifestPath);
            manifest.Book = slug;
            manifest.Toc = toc;
            manifest.Sections = new List<Section>();

            for (int i = 0; i < toc.Count; i++)
            {
                var entry = toc[i];
                var sectionId = $"section_{i + 1:D4}";
                var fileName =
                    $"{i + 1:D3}_{Slugify(entry.Title)}.txt";
                var txtPath = Path.Combine(sectionsDir, fileName);

                var sectionPages = allPages
                    .Where(p => p.PageNumber >= entry.PageStart
                             && p.PageNumber <= entry.PageEnd)
                    .ToList();

                var rawText = string.Join("\n\n",
                    sectionPages.Select(p =>
                    {
                        var t = extractor.RemovePageNumbers(p.Text);
                        t = detector.RemoveRepeatedLines(
                            t, repeatedLines);
                        t = extractor.JoinBrokenLines(t);
                        return extractor.FormatPageWithMarker(p.PageNumber, t);
                    }));

                var fixedText = ocrFix.Apply(rawText);
                File.WriteAllText(txtPath, fixedText,
                    System.Text.Encoding.UTF8);

                manifest.Sections.Add(new Section
                {
                    Id = sectionId,
                    Title = entry.Title,
                    PageStart = entry.PageStart,
                    PageEnd = entry.PageEnd,
                    Status = "extracted",
                    Narrate = entry.Narrate,
                    TxtPath = txtPath
                });

                var percent = 10 + (int)((i + 1.0) 
                    / toc.Count * 85);
                await hubContext.Clients.All.SendAsync(
                    "ExtractProgress",
                    new { slug,
                          message = 
                            $"[{i+1}/{toc.Count}] " +
                            $"{entry.Title} işlendi.",
                          percent });
            }

            manifestSvc.Save(manifestPath, manifest);

            await hubContext.Clients.All.SendAsync(
                "ExtractProgress",
                new { slug, message = "İşlem tamamlandı.", percent = 100, done = true });

            manifestSvc.Unlock(manifestPath);
        }
        catch (Exception ex)
        {
            var svc = new ManifestService();
            svc.Unlock(manifestPath);

            await hubContext.Clients.All.SendAsync(
                "ExtractProgress",
                new { slug, message = $"Hata: {ex.Message}", error = true });
        }
    });

    return Results.Accepted(null, new
    {
        message = "Extract başladı.",
        slug
    });
});

// GET /api/books/{slug}/sections/{id}
// Section metnini oku
app.MapGet("/api/books/{slug}/sections/{id}", 
    (string slug, string id) =>
{
    var manifestPath = Path.Combine(
        repoRoot, "workspace", slug, "manifest.json");

    if (!File.Exists(manifestPath))
        return Results.NotFound(
            new { message = $"{slug} bulunamadı." });

    var svc = new ManifestService();
    var manifest = svc.Load(manifestPath);
    var section = manifest.Sections
        .FirstOrDefault(s => s.Id == id);

    if (section is null)
        return Results.NotFound(
            new { message = $"{id} bulunamadı." });

    // Önce reviewed, yoksa extracted txt'yi oku
    var txtPath = !string.IsNullOrEmpty(section.ReviewedPath)
        && File.Exists(section.ReviewedPath)
            ? section.ReviewedPath
            : section.TxtPath;

    if (!File.Exists(txtPath))
        return Results.NotFound(
            new { message = "Metin dosyası bulunamadı." });

    var content = File.ReadAllText(txtPath,
        System.Text.Encoding.UTF8);

    // content döndükten sonra pages parse et:
    var pages = content
        .Split("=== SAYFA ", StringSplitOptions.RemoveEmptyEntries)
        .Select(block =>
        {
            var lines = block.Split('\n');
            var firstLine = lines[0];
            var pageNumStr = firstLine.Contains(" ===") 
                ? firstLine.Replace(" ===", "").Trim()
                : firstLine.Trim();
            var pageText = string.Join("\n", lines.Skip(1)).Trim();
            return new
            {
                pageNumber = int.TryParse(pageNumStr, out var n) 
                    ? n : 0,
                text = pageText
            };
        })
        .Where(p => p.pageNumber > 0)
        .ToList();

    return Results.Ok(new
    {
        id = section.Id,
        title = section.Title,
        status = section.Status,
        narrate = section.Narrate,
        pageStart = section.PageStart,
        pageEnd = section.PageEnd,
        content,         // ham metin (ayraçlarla)
        pages,           // sayfa bazlı liste
        isReviewed = !string.IsNullOrEmpty(section.ReviewedPath)
    });
});


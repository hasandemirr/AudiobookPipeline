// Slugify yardımcı metod
static string Slugify(string title)
{
    return System.Text.RegularExpressions.Regex
        .Replace(title.ToLowerInvariant(), @"[^a-z0-9]", "_")
        .Trim('_')[..Math.Min(30, title.Length)];
}
